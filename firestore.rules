rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /rag_chunks/{chunkDocId} {
      // Your browser app does not write to Firestore directly; it calls the backend.
      // The backend uses Firebase Admin SDK, which bypasses these rules.
      // These rules are primarily a safety net for any accidental client-side access.

      // Allow authenticated users to read.
      allow read: if request.auth != null;

      // Allow writes only for admins (set `admin` as a custom claim).
      allow write: if request.auth != null && request.auth.token.admin == true;
    }
  }
}

